# Local development settings. Copy this file to .env and you're done.
# (The project auto-loads .env on startup.)

# For local dev this random key is fine. Generate a fresh one for production:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=X-NksEVkV3bAOU-XgKjR37ASgg5XmjZ82d9CbwVAi_SEWrAmoOtA05EgzrE23O4zuZ8

# 1 = local dev (debug pages, no host check). Set to 0 in production.
DEBUG=1

# Comma-separated. In production, set this to your real domain.
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional. Leave unset to use SQLite (default).
# Example for Postgres: postgres://user:pass@host:5432/dbname
# DATABASE_URL=

# Optional Google Books API key. Without one, the public Google Books endpoint
# is aggressively rate-limited (often blocked after 1-2 anonymous requests),
# so PageTurner uses Open Library as the primary source until you set a key.
# Get one free at: https://console.cloud.google.com/apis/credentials
# GOOGLE_BOOKS_API_KEY=

# Google Books API. The public endpoint works without a key; setting one
# gives you a higher rate limit. Get one at:
#   https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=AIzaSyCU035qDO1AEZtGB5gz8OJze2dvEOP5Iuw

# Require email verification before users can send friend requests or post
# reviews. Off by default so local dev is friction-free. Turn on in prod.
REQUIRE_EMAIL_VERIFICATION=0

# Max friend requests a user can send in any rolling hour.
FRIEND_REQUEST_RATE_LIMIT_PER_HOUR=20

# Comma-separated words to filter out of reviews. Conservative starter list.
PROFANITY_BLOCKLIST=

# Email (only used when DEBUG=0; dev prints emails to the terminal).
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=PageTurner <noreply@yourdomain.com>
